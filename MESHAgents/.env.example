OPENAI_API_KEY="OPENAI_API_KEY"
GPT_MODEL = "gpt-5-mini-2025-08-07"  # "gpt-4o-mini-2024-07-18" "gpt-5-nano-2025-08-07"
MAX_TOKENS = 2000

# ---- Provider switch: one variable flips OpenAI <-> local Ollama (see ../ollama_provider.md) ----
# MESH_PROVIDER=ollama                  # openai (default) | ollama   <-- the ONE change
# OLLAMA_HOST=http://localhost:11434    # provider appends /v1
# MESH_LLM_MODEL=qwen2.5:7b             # Ollama chat model (any pulled tag)
# MESH_EMBED_MODEL=nomic-embed-text     # Ollama embedding model
# In ollama mode OPENAI_API_KEY is unused (a dummy is auto-set); no real key needed.
# Prereq:  ollama serve  &&  ollama pull qwen2.5:7b nomic-embed-text