# Copy to .env and fill in your key:  cp .env.example .env
# .env is gitignored — NEVER commit your real key.

# ============================================================
# PROVIDER SWITCH — one variable flips OpenAI <-> local Ollama
# ============================================================
# MESH_PROVIDER=openai          # openai (default) | ollama   <-- the ONE change

# ---- OpenAI profile (default) ----
OPENAI_API_KEY=your_sk_key_here
# GPT_MODEL=gpt-5-mini-2025-08-07
# MAX_TOKENS=2000

# ---- Ollama profile (local, no internet; for the HPP/Pheno TRE VM) ----
# Uncomment these and set MESH_PROVIDER=ollama. No OpenAI key needed (a dummy is auto-set).
#   Prereq:  ollama serve  &&  ollama pull qwen2.5:7b nomic-embed-text     (see ollama_provider.md)
# MESH_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434     # provider appends /v1
# MESH_LLM_MODEL=qwen2.5:7b              # chat model (any pulled Ollama tag)
# MESH_EMBED_MODEL=nomic-embed-text      # embedding model

# ---- MESHAgents 3-stage protocol (mesh_core.py) — provider-agnostic ----
# MESH_MAX_ROUNDS=10            # consensus rounds cap (paper default)
# MESH_DRY_RUN=1               # skip all LLM calls (statistical stub; for fast/free testing)
# MESH_LLM_BASE_URL=           # explicit OpenAI-compatible endpoint override (wins over the provider default)
# MESH_EMBED_BASE_URL=         # explicit embeddings endpoint override
# DATA_PATH=MESHAgents/data/merged_data.csv

# ---- optional: Claude-3.5 baseline (phewas_baselines.py) ----
# ANTHROPIC_API_KEY=
