# Copy to .env and fill in your key:  cp .env.example .env
# .env is gitignored — NEVER commit your real key.

OPENAI_API_KEY=your_sk_key_here

# ---- optional overrides ----
# GPT_MODEL=gpt-5-mini-2025-08-07
# MAX_TOKENS=2000
# DATA_PATH=MESHAgents/data/merged_data.csv

# ---- MESHAgents 3-stage protocol (mesh_core.py) ----
# MESH_MAX_ROUNDS=10            # consensus rounds cap (paper default)
# MESH_DRY_RUN=1               # skip all LLM calls (statistical stub; for fast/free testing)
# MESH_LLM_BASE_URL=           # point to a local OpenAI-compatible endpoint (e.g. in the HPP TRE)
# MESH_LLM_MODEL=              # model id for the local/alternate endpoint
# MESH_EMBED_MODEL=text-embedding-3-small

# ---- optional: Claude-3.5 baseline (phewas_baselines.py) ----
# ANTHROPIC_API_KEY=
